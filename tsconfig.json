{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "src/**/*.ts",
    "test/rules/**/*.test.ts",
    "test/utils/**/*.ts",
    "test/**/*.mjs",
    "vitest.config.ts"
  ],
  "exclude": [
    "test/fixtures/**"
  ]
}
